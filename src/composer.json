{
	"name": "rdurica/oaza",
	"description": "Refactored Salt Cave webpage providing information on salt therapy, featuring a booking system and a responsive design",
	"homepage": "https://oazahb.cz",
	"type": "project",
	"license": ["MIT"],
	"authors": [
		{
			"name": "Robert Durica",
			"homepage": "https://rdurica.robbyte.net/"
		},
		{
			"name": "David Grudl",
			"homepage": "https://davidgrudl.com"
		},
		{
			"name": "Nette Community",
			"homepage": "https://nette.org/contributors"
		}
	],
	"require": {
		"cweagans/composer-patches": "^2.0",
		"php": ">= 8.5",
		"nette/application": "^3.2",
		"nette/bootstrap": "^3.2",
		"nette/caching": "^3.3",
		"nette/database": "^3.2",
		"nette/di": "^3.2",
		"nette/finder": "^3.0",
		"nette/forms": "^3.2",
		"nette/http": "^3.3",
		"nette/robot-loader": "^4.0",
		"nette/security": "^3.2",
		"nette/utils": "^4.0",
		"latte/latte": "^3.0",
		"tracy/tracy": "^2.10",
		"contributte/translation": "^2.0",
		"ublaboo/datagrid": "7.1.1",
		"nette/mail": "^4.0",
		"contributte/sentry": "^0.5.0"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^4.0.1"
	},
	"scripts": {
		"phpcs": "./vendor/bin/phpcs --standard=PSR12 app/",
		"phpcbf": "./vendor/bin/phpcbf --standard=PSR12 app/"
	},
	"config": {
		"allow-plugins": {
			"cweagans/composer-patches": true
		}
	},
	"extra": {
		"patches": {
			"ublaboo/datagrid": {
				"Remove deprecated ReflectionProperty::setAccessible() calls for PHP 8.5": "patches/ublaboo-datagrid-php-8.5-compat.patch"
			}
		}
	}
}
